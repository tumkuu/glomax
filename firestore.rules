rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      // Guest checkout: create + rollback delete
      allow create, delete: if true;
      allow read, update: if false;
    }

    match /promotions/{promoId} {
      // Public read for home page; writes go through the admin API (client SDK)
      allow read: if true;
      allow write: if true;
    }
  }
}
